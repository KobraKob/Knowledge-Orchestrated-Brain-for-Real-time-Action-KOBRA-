# KOBRA v2 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required: Groq API key (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Required: Picovoice Porcupine access key (https://console.picovoice.net)
PORCUPINE_ACCESS_KEY=your_porcupine_access_key_here

# Optional: path to your Porcupine .ppn wake-word model file
# Default: hey-kobra_en_windows_v3_0_0.ppn (in project root)
# WAKE_WORD_PATH=hey-kobra_en_windows_v3_0_0.ppn
